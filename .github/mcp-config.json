{
  "mcpServers": {
    "context7": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {},
      "tools": ["*"]
    },
    "context-mode": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "context-mode"],
      "env": {},
      "tools": ["*"]
    },
    "gemini-cli": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "gemini-mcp-tool"],
      "env": {},
      "tools": ["*"]
    }
  }
}
